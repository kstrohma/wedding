---
interface Props {
  title: string;
  subtitle: string;
  venue_name: string;
  address: string;
  venue_image?: string;
  lang: 'en' | 'de';
}
const { title, subtitle, venue_name, address, venue_image, lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const imageUrl = venue_image ? `${base}${venue_image}` : null;
const directionsLabel = lang === 'en' ? 'Get directions' : 'Route berechnen';
const mapsDirectionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(address)}`;
---

<section class="section">
  <div class="container">
    <div class="venue-top">
      {imageUrl && (
        <div class="venue-image-wrap">
          <img src={imageUrl} alt={venue_name} class="venue-image" />
        </div>
      )}
      <div class="venue-info">
        <h2 class="venue-name">{venue_name}</h2>
        <p class="venue-address">{address}</p>
        <a href={mapsDirectionsUrl} target="_blank" rel="noopener noreferrer" class="directions-link">
          {directionsLabel} &rarr;
        </a>
      </div>
    </div>

    <div class="map-wrap">
      <iframe
        src={`https://maps.google.com/maps?q=${encodeURIComponent(venue_name + ', ' + address)}&output=embed`}
        width="100%"
        height="450"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={venue_name}
      ></iframe>
    </div>
  </div>
</section>

<style>
  .venue-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .venue-image-wrap {
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .venue-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .venue-name {
    font-family: var(--font-heading);
    font-size: var(--size-3xl);
    font-weight: 400;
    margin-bottom: var(--space-sm);
  }

  .venue-address {
    color: var(--color-muted);
    margin-bottom: var(--space-md);
    font-size: var(--size-base);
  }

  .directions-link {
    display: inline-block;
    font-size: var(--size-sm);
    letter-spacing: 0.05em;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-sm);
    transition: background var(--transition), color var(--transition);
  }

  .directions-link:hover {
    background: var(--color-accent);
    color: var(--color-white);
  }

  .map-wrap {
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .venue-top {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .venue-name {
      font-size: var(--size-2xl);
    }

    .map-wrap iframe {
      height: 280px;
    }
  }
</style>
