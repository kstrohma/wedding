---
interface Props {
  partner1: string;
  partner2: string;
  date: string;
  intro: string;
  hero_image?: string;
  lang: 'en' | 'de';
}
const { partner1, partner2, date, intro, hero_image, lang } = Astro.props;
const rsvpLabel = 'RSVP';
const rsvpPreamble = lang === 'de' ? 'Zur Zu- oder Absage' : 'Confirm your attendance';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rsvpHref = `${base}/${lang}/rsvp/`;
const heroImageUrl = hero_image ? `${base}${hero_image}` : null;
---

<section class="hero" style={heroImageUrl ? `background-image: url('${heroImageUrl}')` : ''}>
  <div class="hero-overlay">
    <div class="container hero-content">
      <p class="hero-names">{partner1} <span class="amp">&amp;</span> {partner2}</p>
      <div class="divider" style="margin-inline: auto;"></div>
      <p class="hero-date">{date}</p>
      <p class="hero-intro">{intro}</p>
      <div class="hero-cta-wrap">
        {rsvpPreamble && <p class="hero-cta-preamble">{rsvpPreamble}</p>}
        <a href={rsvpHref} class="hero-cta">{rsvpLabel}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    background-color: var(--color-surface);
    background-size: cover;
    background-position: center;
    text-align: center;
  }

  .hero-overlay {
    width: 100%;
    background: rgba(250, 248, 244, 0.80);
    padding-block: var(--space-2xl);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-names {
    font-family: var(--font-heading);
    font-size: var(--size-4xl);
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .amp {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-date {
    font-family: var(--font-body);
    font-size: var(--size-lg);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: var(--space-md);
  }

  .hero-intro {
    max-width: 520px;
    color: var(--color-muted);
    margin-bottom: var(--space-lg);
  }

  .hero-cta-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-sm);
  }

  .hero-cta-preamble {
    font-size: var(--size-sm);
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .hero-cta {
    display: inline-block;
    padding: 0.85rem 3rem;
    background: var(--color-accent);
    border: 1px solid var(--color-accent);
    color: var(--color-white);
    font-size: var(--size-sm);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    transition: background var(--transition), color var(--transition), box-shadow var(--transition);
    border-radius: var(--radius-sm);
    box-shadow: 0 2px 12px rgba(0,0,0,0.12);
  }
  .hero-cta:hover {
    background: transparent;
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .hero-names { font-size: var(--size-2xl); }
    .hero-overlay { padding-block: var(--space-xl); }
    .hero-intro { max-width: 100%; }
  }
</style>
