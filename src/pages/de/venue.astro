---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Venue from '../../components/Venue.astro';
import { loadData } from '../../lib/data';

const data = loadData<{
  title: string;
  subtitle: string;
  venue_name: string;
  address: string;
  venue_image?: string;
}>('de', 'venue');
---

<BaseLayout title={data.title} lang="de">
  <Venue {...data} lang="de" />
</BaseLayout>
