---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Venue from '../../components/Venue.astro';
import { loadData } from '../../lib/data';

const data = loadData<{
  title: string;
  subtitle: string;
  venue_name: string;
  address: string;
  venue_image?: string;
}>('en', 'venue');
---

<BaseLayout title={data.title} lang="en">
  <Venue {...data} lang="en" />
</BaseLayout>
