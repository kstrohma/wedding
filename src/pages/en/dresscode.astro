---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Dresscode from '../../components/Dresscode.astro';
import { loadData } from '../../lib/data';

const data = loadData<{
  title: string;
  dresscode: string;
  description: string;
  color_image?: string;
}>('en', 'dresscode');
---

<BaseLayout title={data.title} lang="en">
  <Dresscode {...data} />
</BaseLayout>
