---
import '../styles/theme.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  lang: 'en' | 'de';
  description?: string;
}

const { title, lang, description = '' } = Astro.props;
const validToken = import.meta.env.PUBLIC_AUTH_TOKEN;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script define:vars={{ validToken }}>
      (function () {
        const LS_KEY = 'wedding_auth';
        const params = new URLSearchParams(window.location.search);
        const token = params.get('token');

        if (token) {
          if (token === validToken) {
            localStorage.setItem(LS_KEY, 'true');
          }
          params.delete('token');
          const newSearch = params.toString();
          history.replaceState(null, '', window.location.pathname + (newSearch ? '?' + newSearch : '') + window.location.hash);
        }

        if (localStorage.getItem(LS_KEY) !== 'true') {
          window.location.replace('/unauthorized');
        }
      })();
    </script>
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
